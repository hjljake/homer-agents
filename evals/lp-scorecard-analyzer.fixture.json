        "lp.traffic_type": "Warm -- visitors who already know this brand or are existing customers",
        "lp.traffic_source": "Email campaign",
        "lp.goal": "Upgrade to a paid plan or higher tier"
      },
      "output_must_contain": {
        "sections": ["scorecard_results", "overall_score", "grade", "top_strengths", "top_issues", "priority_fixes", "business_context", "message_match_assessment"],
        "score_range": [0, 100],
        "top_strengths_count": 3,
        "top_issues_count": 3,
        "priority_fixes_count": [1, 10],
        "scorecard_sections": ["hero_section", "below_the_fold", "social_proof", "offer_clarity", "mobile_experience", "brand_and_design", "technical_and_trust"]
      },
      "output_must_not_contain": [],
      "kb_save_check": {
        "title_pattern": "LP Scorecard Analysis:.*Warm.*",
        "yaml_type": "lp-scorecard-analysis",
        "yaml_fields_present": ["score", "grade", "traffic_source", "page_goal", "visitor_relationship", "lead_type", "research_date", "page_url"]
      }
    },
    {
