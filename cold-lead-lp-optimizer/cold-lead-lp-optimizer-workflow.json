{
  "name": "cold-lead-lp-optimizer",
  "description": "Cold Lead Landing Page Optimizer — analyzes a landing page targeting cold traffic, scores it against the Cold Lead Scorecard, then generates 2 A/B test variants (incremental improvement + structural rethink) with detailed build-out instructions saved to KB",
  "status": "active",
  "coordination_pattern": "sequential",
  "config": {
    "output_config": {
      "create_artifact": true,
      "artifact_title": "Cold Lead LP Optimization: A/B Test Plan"
    }
  },
  "trigger_config": {
    "triggers": [
      { "type": "event", "event": "coo_action_assigned" },
      { "type": "manual" }
    ]
  },
  "steps": [
    {
      "id": "analyze_landing_page",
      "name": "Analyze Landing Page (Cold Lead Scorecard)",
      "type": "agent",
      "config": {
        "agent_definition_id": "{{cold-lead-lp-analyzer-id}}",
        "timeout": 300000
      }
    },
    {
      "id": "confirm_scorecard",
      "name": "Confirm Scorecard Results",
      "type": "pause",
      "config": {
        "title": "Review your Cold Lead Landing Page Scorecard",
        "description": "We've analyzed your landing page through the lens of cold traffic conversion. Review the scores and tell us what we got right, what we missed, and which areas matter most to you.",
        "ui_schema": {
          "sections": [
            {
              "title": "Scorecard Results",
              "description": "Here's how your landing page scored across 7 cold-traffic conversion dimensions. Each section is weighted for cold visitor psychology — hero and social proof carry the most weight because cold visitors decide in 3-8 seconds.",
              "fields": [
                {
                  "id": "scorecard_display",
                  "type": "readonly",
                  "source": "steps.analyze_landing_page.output.scorecard_results"
                },
                {
                  "id": "overall_score_display",
                  "type": "readonly",
                  "source": "steps.analyze_landing_page.output.overall_score"
                },
                {
                  "id": "top_strengths_display",
                  "type": "readonly",
                  "source": "steps.analyze_landing_page.output.top_strengths"
                },
                {
                  "id": "top_issues_display",
                  "type": "readonly",
                  "source": "steps.analyze_landing_page.output.top_issues"
                }
              ]
            },
            {
              "title": "Your Feedback",
              "description": "Help us refine the analysis before we generate optimization variants.",
              "fields": [
                {
                  "id": "scorecard_accurate",
                  "type": "boolean",
                  "label": "Does this assessment feel accurate overall?",
                  "required": true
                },
                {
                  "id": "score_corrections",
                  "type": "textarea",
                  "label": "What did we get wrong or miss?",
                  "placeholder": "E.g., 'The testimonials section actually has 5 reviews but they're in a carousel you might not have seen', 'We intentionally don't show pricing on this page', 'The mobile version has a sticky CTA you may not have detected'...",
                  "required": false
                },
                {
                  "id": "priority_sections",
                  "type": "multi_select",
                  "label": "Which areas are most important to optimize? (pick 2-3)",
                  "required": true,
                  "options": [
                    "Hero Section (headline, subheadline, CTA, trust anchor)",
                    "Below-the-Fold Sequence (body content, benefit framing)",
                    "Social Proof (testimonials, logos, case studies, numbers)",
                    "Offer Clarity (what you get, pricing, risk reversal)",
                    "Mobile Experience",
                    "Brand Identity & Design",
                    "Technical & Trust Fundamentals"
                  ]
                },
                {
                  "id": "optimization_constraints",
                  "type": "textarea",
                  "label": "Any constraints we should know about?",
                  "placeholder": "E.g., 'We can't change the hero image — it's a brand requirement', 'We use Unbounce and can only edit within their builder', 'Budget for implementation is limited', 'We need to keep the form fields because sales requires them'...",
                  "required": false
                }
              ]
            }
          ]
        }
      },
      "input_mapping": {
        "scorecard_results": "steps.analyze_landing_page.output.scorecard_results",
        "overall_score": "steps.analyze_landing_page.output.overall_score",
        "top_strengths": "steps.analyze_landing_page.output.top_strengths",
        "top_issues": "steps.analyze_landing_page.output.top_issues"
      }
    },
    {
      "id": "optimize_headers",
      "name": "Optimize Headers & Subheaders",
      "type": "agent",
      "config": {
        "agent_definition_id": "{{cold-lead-header-optimizer-id}}",
        "timeout": 300000
      },
      "input_mapping": {
        "scorecard_results": "steps.analyze_landing_page.output.scorecard_results",
        "business_context": "steps.analyze_landing_page.output.business_context",
        "page_url": "steps.analyze_landing_page.output.page_url",
        "page_goal": "steps.analyze_landing_page.output.page_goal",
        "traffic_source": "steps.analyze_landing_page.output.traffic_source",
        "score_corrections": "steps.confirm_scorecard.output.score_corrections",
        "priority_sections": "steps.confirm_scorecard.output.priority_sections",
        "optimization_constraints": "steps.confirm_scorecard.output.optimization_constraints"
      }
    },
    {
      "id": "optimize_icp_positioning",
      "name": "Optimize ICP Positioning",
      "type": "agent",
      "config": {
        "agent_definition_id": "{{cold-lead-icp-optimizer-id}}",
        "timeout": 300000
      },
      "input_mapping": {
        "scorecard_results": "steps.analyze_landing_page.output.scorecard_results",
        "business_context": "steps.analyze_landing_page.output.business_context",
        "page_url": "steps.analyze_landing_page.output.page_url",
        "page_goal": "steps.analyze_landing_page.output.page_goal",
        "traffic_source": "steps.analyze_landing_page.output.traffic_source",
        "score_corrections": "steps.confirm_scorecard.output.score_corrections",
        "priority_sections": "steps.confirm_scorecard.output.priority_sections",
        "optimization_constraints": "steps.confirm_scorecard.output.optimization_constraints"
      }
    },
    {
      "id": "optimize_layout",
      "name": "Optimize Page Layout",
      "type": "agent",
      "config": {
        "agent_definition_id": "{{cold-lead-layout-optimizer-id}}",
        "timeout": 300000
      },
      "input_mapping": {
        "scorecard_results": "steps.analyze_landing_page.output.scorecard_results",
        "business_context": "steps.analyze_landing_page.output.business_context",
        "page_url": "steps.analyze_landing_page.output.page_url",
        "page_goal": "steps.analyze_landing_page.output.page_goal",
        "traffic_source": "steps.analyze_landing_page.output.traffic_source",
        "score_corrections": "steps.confirm_scorecard.output.score_corrections",
        "priority_sections": "steps.confirm_scorecard.output.priority_sections",
        "optimization_constraints": "steps.confirm_scorecard.output.optimization_constraints"
      }
    },
    {
      "id": "generate_ab_variants",
      "name": "Generate A/B Test Variants",
      "type": "agent",
      "config": {
        "agent_definition_id": "{{cold-lead-ab-variant-builder-id}}",
        "timeout": 300000
      },
      "input_mapping": {
        "scorecard_results": "steps.analyze_landing_page.output.scorecard_results",
        "overall_score": "steps.analyze_landing_page.output.overall_score",
        "score_corrections": "steps.confirm_scorecard.output.score_corrections",
        "priority_sections": "steps.confirm_scorecard.output.priority_sections",
        "optimization_constraints": "steps.confirm_scorecard.output.optimization_constraints",
        "business_context": "steps.analyze_landing_page.output.business_context",
        "page_url": "steps.analyze_landing_page.output.page_url",
        "traffic_source": "steps.analyze_landing_page.output.traffic_source",
        "page_goal": "steps.analyze_landing_page.output.page_goal",
        "header_recommendations": "steps.optimize_headers.output",
        "icp_recommendations": "steps.optimize_icp_positioning.output",
        "layout_recommendations": "steps.optimize_layout.output"
      }
    }
  ]
}
